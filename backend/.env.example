# ─── Valorant Scout — environment ──────────────────────────────────────────
# Copy this file to ".env" and fill in what you need. Everything has a sane
# default, and the app renders fully in DEMO mode with nothing set.

# Official Riot API key — https://developer.riotgames.com
# account-v1 works on a personal key; val-match-v1 needs production approval.
RIOT_API_KEY=

# Your PUUID is detected automatically from the running VALORANT client — there
# is nothing to set here for the live scoreboard.

# Shard:  na | eu | ap | kr | latam | br
RIOT_REGION=na

# Data source:  auto | local | official | demo
#   auto      local client if VALORANT is running, else official API, else demo
#   local     force the unofficial local client API (needs the game open)
#   official  force the official Riot API (needs val-match-v1 production access)
#   demo      always use deterministic generated data (best for previewing UI)
DATA_SOURCE=auto

# Ports
BACKEND_PORT=5000
FRONTEND_PORT=3000
PLAYER_CACHE_TTL=60

# ─── Hosted frontend bridge ────────────────────────────────────────────────
# Where the normal hosted Next.js frontend is served. The desktop
# app opens FRONTEND_URL/dashboard?mode=local&port=<WS_PORT>&s=<token> and the
# hosted site connects back over the local WebSocket below. NEVER hardcode a
# production domain in code — it always comes from here.
FRONTEND_URL=https://valorantscout.vercel.app

# Developer opt-in only. A private checkout that happens to contain frontend/
# still uses the hosted site unless this is true (and install.bat -Frontend was
# run). This keeps normal startup free of any Node.js requirement.
SCOUT_LOCAL_FRONTEND=false
# LOCAL_FRONTEND_URL=http://localhost:3000

# Loopback port for the local WebSocket bridge (binds 127.0.0.1 only).
WS_PORT=7878

# Where the desktop app fetches short-lived, channel-scoped Ably tokens for
# remote/phone mode. This is the Next.js serverless route (it holds ABLY_API_KEY,
# the desktop app never does). Defaults to FRONTEND_URL/api/ably-token.
ABLY_TOKEN_ENDPOINT=https://valorantscout.vercel.app/api/ably-token

# NOTE: ABLY_API_KEY does NOT belong here. The root Ably key lives ONLY in the
# Next.js/Vercel server environment — never in the distributed Python app.

# ─── Discord Rich Presence ─────────────────────────────────────────────────
# Shows your rank + lobby/agent-select/in-game + map + mode + score on your
# Discord profile (needs the Discord desktop app running).
# Set to false to disable. (The Discord app id is fixed in code so the map/rank
# /agent images always resolve — it isn't configurable here.)
DISCORD_RPC=true

# ─── DANGER ZONE ───────────────────────────────────────────────────────────
# Lets the Instalock panel actually drive your game client. This automates agent
# select and MAY VIOLATE RIOT'S TERMS OF SERVICE (risk of account suspension/
# ban). Even when true, the panel's per-action dry-run toggle is the real gate —
# nothing touches the client until you turn dry-run OFF. Set false to hard-lock
# everything into safe dry-run mode.
ALLOW_LIVE_INSTALOCK=true
